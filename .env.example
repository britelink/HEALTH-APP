# MongoDB connection string (Atlas or local). Database name is taken from the URI or defaults to "health_app".
MONGODB_URI="mongodb://localhost:27017/health_app"

# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Secret used to sign session JWTs. Use a long random string in production.
AUTH_SECRET="change-me-to-a-long-random-string"
